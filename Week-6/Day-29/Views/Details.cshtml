﻿@using WebApplication1.Models
@model Product

<h1 class="display-5">Employee Controller - Details </h1>


@if (Model == null)
{
    <p>Requested Employee Details are not available</p>
}
else
{
    <div>
        Product Id : @Model.Id  <br />
        Product Name : @Model.Name  <br />
        Product Price : @Model.Price  <br />
        Product Category : @Model.Category  <br />
    </div>
}

<form method="post">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>






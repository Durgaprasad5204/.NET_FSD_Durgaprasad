@using WebApplication1.Models
@model Product

<h1 class="display-5">Product Controller - Delete </h1>

<hr />

@if (Model == null)
{
    <p>Required product details are missing</p>
}
else
{
    <div>
        Product Id : @Model.Id  <br />
        Product Name : @Model.Name  <br />
        Product Price : @Model.Price  <br />
        Product Category : @Model.Category  <br />

    </div>
}

<form asp-action="delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <p>Do you want to delete this product details?</p>
    <button type="submit" class="btn btn-success">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@model IEnumerable<WebApplication1.Models.Product>

<h2>Product List</h2>

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Price</th>
        <th>Category</th>
        <th>Action</th>
    </tr>

    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Id</td>
            <td>@p.Name</td>
            <td>@p.Price</td>
            <td>@p.Category</td>
            <td>
                <a asp-action="Details" asp-route-id="@p.Id">View</a>
            </td>
        </tr>
    }
</table>
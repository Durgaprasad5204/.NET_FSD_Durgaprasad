@using WebApplication1.Models
@model List<ContactInfo>


<h3 class="display-5">Contact Controller - Search</h3>

<hr />
<table class="table" border="1" cellpadding="10" cellspacing="0">
    <thead>
        <tr>
            <th>Id</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Company Name</th>
            <th>Mobile Number</th>
            <th>Email</th>
            <th>Designation</th>
            

        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ContactId</td>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.CompanyName</td>
                <td>@item.MobileNo</td>
                <td>@item.EmailId</td>
                <td>@item.Designation</td>
                
            </tr>
        }
    </tbody>
</table>

<br />

<a asp-action="ShowContacts" class="btn btn-secondary">Back to List</a>
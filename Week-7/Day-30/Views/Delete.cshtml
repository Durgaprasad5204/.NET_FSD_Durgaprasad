@using WebApplication1.Models
@model ContactInfo

<h3 class="display-5">Contact Controller - Delete </h3>

@if (Model == null)
{
    <p>Requested Contact Details are not available</p>
}
else
{
    <div>
        Contact Id : @Model.ContactId  <br />
        Contact Name : @Model.FirstName @Model.LastName  <br />
        Company Name : @Model.CompanyName  <br />
        Email Id : @Model.EmailId  <br />
        Mobile No : @Model.MobileNo  <br />
        Designation : @Model.Designation   <br />
    </div>
}

<form asp-action="delete" method="post">
    <input type="hidden" name="id" value="@Model.ContactId" />
    <p>Do you want to delete this Contact details?</p>
    <button type="submit" class="btn btn-success">Delete</button>
    <a asp-action="ShowContacts" class="btn btn-secondary">Back to List</a>
</form>
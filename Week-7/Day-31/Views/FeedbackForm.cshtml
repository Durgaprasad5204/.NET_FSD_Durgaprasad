@model WebApplication1.Models.Feedback

@{
    ViewData["Title"] = "Feedback Form";
}

<h2>Feedback Form</h2>
<hr />

<form asp-action="SubmitFeedback" asp-controller="Feedback" method="post">

    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div>
        <label asp-for="Comments"></label>
        <textarea asp-for="Comments" class="form-control"></textarea>
    </div>

    <div>
        <label asp-for="Rating"></label>
        <input asp-for="Rating" type="number" min="1" max="5" class="form-control" />
    </div>

    <input type="submit" value="Submit Feedback" class="btn btn-success" />
</form>

<hr />

@if (ViewData["Message"] != null)
{
    <div>
        @ViewData["Message"]
    </div>
}
@model IEnumerable<WebApplication2.Models.Movie>

<h2>Movie List</h2>

<a asp-action="Create" class="btn btn-primary">Add New Movie</a>

<table class="table table-bordered mt-3">
    <tr>
        <th>Id</th>
        <th>Title</th>
        <th>Genre</th>
        <th>Release Date</th>
        <th>Price</th>
        <th>Rating</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Title</td>
            <td>@item.Genre</td>
            <td>@item.ReleaseDate.ToShortDateString()</td>
            <td>@item.Price</td>
            <td>@item.Rating</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
</table>
@model WebApplication2.Models.ContactInfo

@{
    ViewData["Title"] = "Add Contact";
}

<h1>Add New Contact</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="AddContact">
            <div class="form-group mb-2">
                <label asp-for="ContactId" class="control-label">Contact ID</label>
                <input asp-for="ContactId" class="form-control" type="number" required />
            </div>
            <div class="form-group mb-2">
                <label asp-for="FirstName" class="control-label">First Name</label>
                <input asp-for="FirstName" class="form-control" required />
            </div>
            <div class="form-group mb-2">
                <label asp-for="LastName" class="control-label">Last Name</label>
                <input asp-for="LastName" class="form-control" required />
            </div>
            <div class="form-group mb-2">
                <label asp-for="CompanyName" class="control-label">Company Name</label>
                <input asp-for="CompanyName" class="form-control" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="EmailId" class="control-label">Email ID</label>
                <input asp-for="EmailId" class="form-control" type="email" required />
            </div>
            <div class="form-group mb-2">
                <label asp-for="MobileNo" class="control-label">Mobile Number</label>
                <input asp-for="MobileNo" class="form-control" type="tel" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Designation" class="control-label">Designation</label>
                <input asp-for="Designation" class="form-control" />
            </div>
            <div class="form-group">
                <input type="submit" value="Save Contact" class="btn btn-success" />
                <a asp-action="ShowContacts" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>